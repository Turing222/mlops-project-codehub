# Secrets are loaded from Docker secrets, not this env file.
# Required secret files by default:
#   ./secrets/smoke/secret_key.txt
#   ./secrets/smoke/postgres_password.txt
#   ./secrets/smoke/redis_password.txt
#
# Optional secret file overrides:
# SMOKE_GEMINI_API_KEY_FILE=./secrets/smoke/gemini_api_key.txt
# SMOKE_RAG_EMBED_API_KEY_FILE=./secrets/smoke/rag_embed_api_key.txt
# SMOKE_LANGFUSE_SECRET_KEY_FILE=./secrets/smoke/langfuse_secret_key.txt
POSTGRES_USER=admin
POSTGRES_DB=postgres
POSTGRES_SERVER=postgres
REDIS_HOST=redis
REDIS_PORT=6379
LLM_PROVIDER=gemini
GEMINI_MODEL_NAME=gemini-2.5-flash
# DeepSeek is OpenAI-compatible. To test it, set LLM_PROVIDER=deepseek
# and set SMOKE_DEEPSEEK_API_KEY_FILE. DEEPSEEK_MODEL_NAME can also be
# deepseek-reasoner, deepseek-v4-flash, or deepseek-v4-pro.
# SMOKE_DEEPSEEK_API_KEY_FILE=./secrets/smoke/deepseek_api_key.txt
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL_NAME=deepseek-chat
RAG_EMBED_PROVIDER=google
RAG_EMBED_MODEL_NAME=gemini-embedding-001
RAG_EMBED_DIM=768
KNOWLEDGE_STORAGE_ROOT=/data/knowledge_files
ENABLE_OTEL_METRICS=false
ENABLE_OTEL_TRACES=false
OTEL_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# Full Grafana observability profile:
#   docker compose --env-file .env.smoke --env-file deploy/monitoring/observability.env.template --profile observability -f docker-compose.db.yml up
# ENABLE_OTEL_METRICS=true
# OTEL_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# PROMETHEUS_OTLP_ENDPOINT=http://otel-collector:4318/v1/metrics
# Langfuse tracing:
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
